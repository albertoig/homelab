releases:
  # Longhorn - Cloud-native distributed block storage for Kubernetes
  # https://github.com/longhorn/longhorn/blob/master/chart/values.yaml
  - name: longhorn
    namespace: longhorn-system
    createNamespace: true
    chart: longhorn/longhorn
    version: "v1.11.1"
    wait: true
    labels:
      app: storage
    inherit:
    - template: values_gotmpl_and_secrets

  # MetalLB - Load balancer for Kubernetes
  # https://github.com/metallb/metallb/blob/main/charts/metallb/values.yaml
  - name: metallb
    namespace: metallb-system
    createNamespace: true
    chart: metallb/metallb
    version: "0.15.3"
    wait: true
    labels:
      app: networking
    inherit:
    - template: values_gotmpl_and_secrets

  # MetalLB Configuration - IP Address Pool and L2 Advertisement
  - name: metallb-config
    namespace: metallb-system
    createNamespace: true
    chart: charts/metallb-config
    version: "0.15.3"
    wait: true
    disableValidation: true
    labels:
      app: networking
    needs:
      - metallb-system/metallb
    inherit:
    - template: values_gotmpl_and_secrets

  # https://github.com/prometheus-community/helm-charts/blob/main/charts/kube-prometheus-stack/values.yaml
  - name: prometheus-stack
    namespace: prometheus
    createNamespace: true
    chart: prometheus-community/kube-prometheus-stack
    version: "82.10.3"
    wait: true
    waitForJobs: true
    disableValidationOnInstall: true
    labels:
      app: monitoring
    needs:
      - longhorn-system/longhorn
      - metallb-system/metallb
      - metallb-system/metallb-config
    inherit:
    - template: values_gotmpl_and_secrets

  # https://github.com/grafana-community/helm-charts/blob/main/charts/grafana/values.yaml
  - name: grafana
    namespace: prometheus
    createNamespace: true
    chart: grafana-community/grafana
    version: "11.3.6"
    wait: true
    waitForJobs: true
    labels:
      app: monitoring
    needs:
      - prometheus/prometheus-stack
      - longhorn-system/longhorn
      - metallb-system/metallb
      - metallb-system/metallb-config
    inherit:
    - template: values_gotmpl_and_secrets
    # Hook to clean up stuck MetalLB services before grafana installation
    hooks:
      - events: ["prepare"]
        command: /bin/sh
        args:
          - "-c"
          - |
            for svc in $(kubectl get svc -n prometheus -l app.kubernetes.io/name=grafana -o name 2>/dev/null); do
              kubectl patch "$svc" -n prometheus -p '{"metadata":{"finalizers":[]}}' --type=merge 2>/dev/null || true
            done

  # Loki - Log aggregation system
  # https://artifacthub.io/packages/helm/grafana/loki?modal=values
  - name: loki
    namespace: prometheus
    createNamespace: true
    chart: grafana-community/loki
    version: "9.2.2"
    wait: true
    labels:
      app: logging
    needs:
      - longhorn-system/longhorn
      - prometheus/prometheus-stack
    inherit:
    - template: values_gotmpl_and_secrets
    # Hook to clean up stuck pods with Longhorn volume mount issues
    hooks:
      - events: ["prepare"]
        command: /bin/sh
        args:
          - "-c"
          - |
            for pod in $(kubectl get pods -n prometheus -o name 2>/dev/null); do
              case $pod in
                *loki*)
                  status=$(kubectl get $pod -n prometheus -o jsonpath='{.status.phase}' 2>/dev/null)
                  if [ "$status" = "Pending" ] || [ "$status" = "ContainerCreating" ]; then
                    echo "Force deleting stuck pod: $pod"
                    kubectl delete $pod -n prometheus --force --grace-period=0 2>/dev/null || true
                  fi
                  ;;
              esac
            done
            sleep 5

  # Alloy - OpenTelemetry collector (log and profile collection)
  # https://artifacthub.io/packages/helm/grafana/alloy?modal=values
  - name: alloy
    namespace: prometheus
    createNamespace: true
    chart: grafana/alloy
    version: "0.12.4"
    wait: true
    labels:
      app: logging
    needs:
      - prometheus/loki
      - prometheus/grafana
      - prometheus/pyroscope
      - prometheus/tempo
    inherit:
    - template: values_gotmpl_and_secrets

  # Tempo - Distributed tracing system
  # https://artifacthub.io/packages/helm/grafana-community/tempo?modal=values&path=serviceMonitor
  - name: tempo
    namespace: prometheus
    createNamespace: true
    chart: grafana-community/tempo
    version: "2.0.0"
    wait: true
    labels:
      app: tracing
    needs:
      - longhorn-system/longhorn
      - prometheus/prometheus-stack
    inherit:
    - template: values_gotmpl_and_secrets
    # Hook to clean up stuck pods with Longhorn volume mount issues
    hooks:
      - events: ["prepare"]
        command: /bin/sh
        args:
          - "-c"
          - |
            for pod in $(kubectl get pods -n prometheus -o name 2>/dev/null); do
              case $pod in
                *tempo*)
                  status=$(kubectl get $pod -n prometheus -o jsonpath='{.status.phase}' 2>/dev/null)
                  if [ "$status" = "Pending" ] || [ "$status" = "ContainerCreating" ]; then
                    echo "Force deleting stuck pod: $pod"
                    kubectl delete $pod -n prometheus --force --grace-period=0 2>/dev/null || true
                  fi
                  ;;
              esac
            done
            sleep 5

  # Pyroscope - Continuous profiling system
  # https://artifacthub.io/packages/helm/grafana/pyroscope?modal=values
  - name: pyroscope
    namespace: prometheus
    createNamespace: true
    chart: grafana/pyroscope
    version: "1.19.1"
    wait: true
    labels:
      app: profiling
    needs:
      - longhorn-system/longhorn
      - prometheus/prometheus-stack
      - metallb-system/metallb
      - metallb-system/metallb-config
    inherit:
    - template: values_gotmpl_and_secrets

  # Traefik - Reverse Proxy and Load Balancer
  # https://github.com/traefik/helm-chart/blob/main/traefik/values.yaml
  - name: traefik
    namespace: traefik
    createNamespace: true
    chart: traefik/traefik
    version: "39.0.6"
    wait: true
    labels:
      app: networking
    needs:
      - metallb-system/metallb
      - metallb-system/metallb-config
      - prometheus/tempo
    inherit:
    - template: values_gotmpl_and_secrets

  # Authentik - Open Source Identity Provider
  # https://github.com/goauthentik/helm/blob/authentik-2026.2.1/charts/authentik/values.yaml
  - name: authentik
    namespace: authentik
    createNamespace: true
    chart: authentik/authentik
    version: "2026.2.1"
    wait: true
    labels:
      app: identity
    needs:
      - longhorn-system/longhorn
      - prometheus/prometheus-stack
    inherit:
    - template: values_gotmpl_and_secrets

  # ArgoCD - GitOps Continuous Delivery
  # https://github.com/argoproj/argo-helm/blob/main/charts/argo-cd/values.yaml
  - name: argocd
    namespace: argocd
    createNamespace: true
    chart: argocd/argo-cd
    version: "9.4.16"
    wait: true
    labels:
      app: gitops
    needs:
      - traefik/traefik
    inherit:
    - template: values_gotmpl_and_secrets
