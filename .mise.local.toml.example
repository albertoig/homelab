# .mise.local.toml — machine-specific overrides (gitignored)
#
# Copy to .mise.local.toml and fill in your values:
#   cp .mise.local.toml.example .mise.local.toml
#
# mise loads this file automatically alongside .mise.toml.
# Never commit .mise.local.toml — it contains secrets.

[env]

# ── Terraform (required for: mise run tf:apply / tf:plan / tf:destroy) ────────
#
# Cloudflare API token for Terraform.
# Permissions: Account > R2 Storage > Edit
# Create at: https://dash.cloudflare.com/ → My Profile → API Tokens
#
CLOUDFLARE_API_TOKEN = ""

# Cloudflare account ID — visible in the dashboard URL or the Overview page
# sidebar (format: 32-character hex string).
TF_VAR_cloudflare_account_id = ""

# R2 bucket name for Velero backups.
# Default: "homelab-velero"
TF_VAR_velero_bucket_name = "homelab-velero"

# R2 bucket location hint.
# Options: WEUR (Western Europe), EEUR (Eastern Europe),
#          APAC (Asia-Pacific), WNAM (Western North America), ENAM (Eastern North America)
# Default: "WEUR"
TF_VAR_velero_bucket_location = "WEUR"

# ── Terraform state backend — Cloudflare R2 ──────────────────────────────────
#
# Stores terraform.tfstate remotely in a Cloudflare R2 bucket (S3-compatible)
# instead of on disk. The S3 backend reads these AWS_* env vars automatically.
#
# Bootstrap (one-time, before running mise run tf:init):
#   1. Create an R2 bucket named "homelab-terraform-state" in the Cloudflare dashboard
#   2. Create an R2 API token: Cloudflare Dashboard → R2 → Manage R2 API Tokens
#      Permissions: Object Read & Write (scoped to homelab-terraform-state)
#   3. Fill in the three values below, then run: mise run tf:init
#
# Note: this is a separate R2 token from the Velero one — different bucket, different token.
#
# R2 S3-compatible endpoint.
# Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# (same account ID as TF_VAR_cloudflare_account_id above)
AWS_ENDPOINT_URL_S3   = ""
# R2 API token key ID and secret for the state bucket
AWS_ACCESS_KEY_ID     = ""
AWS_SECRET_ACCESS_KEY = ""

# ── Kubernetes (optional) ─────────────────────────────────────────────────────
#
# Path to your kubeconfig file if it is not at the default ~/.kube/config.
# Required if you manage multiple clusters and keep separate kubeconfig files.
#
# KUBECONFIG = "~/.kube/homelab"

# ── SOPS / age (optional) ─────────────────────────────────────────────────────
#
# Only needed if you use age instead of PGP for SOPS encryption.
# If you use PGP (default), SOPS reads from your GPG keyring automatically —
# no env var is needed.
#
# SOPS_AGE_KEY_FILE = "~/.config/sops/age/keys.txt"
